<Window x:Class="Verbizky.Win.Register"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Verbizky.Win"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Регистрация" Height="720" Width="1270">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Frame 168.png"
                    Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.ColumnSpan="3"
                             Grid.Row="0"
                             Background="#264c7e"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp7">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="10">
                    <Label Content="Регистрация"
                           x:Name="TitleName"
                           Foreground="#d6e7ff"
                           FontSize="32"
                           FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">

                    <Button x:Name="HomeBT"
                            ToolTip="Главная"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Height="40"
                            Click="HomeBT_Click">
                        <materialDesign:PackIcon Kind="Home"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>

                    <Button x:Name="ExitBT"
                            Margin="5"
                            ToolTip="Выйти"
                            Background="#C84153"
                            BorderThickness="0"
                            Padding="10"
                            Height="40"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}" Cursor="Hand" Click="ExitBT_Click">
                        <materialDesign:PackIcon Kind="ExitRun"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             UniformCornerRadius="15"
                             materialDesign:ElevationAssist.Elevation="Dp5">
            <StackPanel Orientation="Horizontal"
                        Margin="22">
                <StackPanel Margin="10">
                    <TextBox x:Name="SurNameTXT"
                             Width="320"
                             FontSize="22"
                             materialDesign:HintAssist.Hint="Фамилия"
                             Margin="5"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <TextBox x:Name="NameTXT"
                             Width="320"
                             FontSize="22"
                             materialDesign:HintAssist.Hint="Имя"
                             Margin="5"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <TextBox x:Name="PatronymicTXT"
                             Width="320"
                             FontSize="22"
                             materialDesign:HintAssist.Hint="Отчество"
                             Margin="5"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <TextBox x:Name="MailTXT"
                             Width="320"
                             FontSize="22"
                             materialDesign:HintAssist.Hint="Почта"
                             Margin="5"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <TextBox x:Name="PhoneTXT"
                             Width="320"
                             FontSize="22"
                             materialDesign:HintAssist.Hint="Телефон"
                             Margin="5"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>

                    <PasswordBox x:Name="PasswordTXT"
                                 Width="320"
                                 FontSize="22"
                                 materialDesign:HintAssist.Hint="Пароль"
                                 Margin="5"
                                 Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"/>

                    <PasswordBox x:Name="PasswordAccsesTXT"
                                 Width="320"
                                 FontSize="22"
                                 materialDesign:HintAssist.Hint="Повторение пароля"
                                 Margin="5"
                                 Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"/>
                </StackPanel>

                <StackPanel Margin="10">
                    <DatePicker x:Name="Dates"
                                Width="260"
                                Margin="5"
                                FontSize="22"
                                materialDesign:HintAssist.Hint="Дата рождения"
                                Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>

                    <ComboBox x:Name="GenderCB"
                              Width="260"
                              materialDesign:HintAssist.Hint="Пол"
                              FontSize="22"
                              Margin="5"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}">
                        <ComboBoxItem Content="Мужской"/>
                        <ComboBoxItem Content="Женский"/>
                        <ComboBoxItem Content="Фурри"/>
                    </ComboBox>

                    <ComboBox x:Name="CityCB"
                              Width="260"
                              materialDesign:HintAssist.Hint="Страна"
                              FontSize="22"
                              Margin="5"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"/>

                    <Button x:Name="RegisterBT"
                            Content="Зарегестроироваться"
                            FontSize="22"
                            Height="40"
                            Click="register_BTN_Click"
                            Margin="5"/>

                    <Button x:Name="LogInBT"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="Войти"
                            FontSize="22"
                            Height="40"
                            Click="LogInBT_Click"
                            Margin="5"/>
                </StackPanel>
                
                <StackPanel Margin="10">
                    <materialDesign:Card Width="210"
                                         Height="210"
                                         materialDesign:ElevationAssist.Elevation="Dp8"
                                         Background="#FFC1C1C1">
                        <materialDesign:Card Width="185" Height="185">
                            <Grid>
                                <Image x:Name="icon_User_IMG"
                                       Stretch="UniformToFill"/>

                                <Button x:Name="edit_Photo_User_BTN"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Left"
                                        Background="#D35400"
                                        Visibility="Collapsed"
                                        Click="edit_Photo_User_BTN_Click"
                                        Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                        Padding="0" Margin="5"
                                        Width="45" Height="45"
                                        BorderThickness="0">
                                    <materialDesign:PackIcon Kind="ImageEdit"
                                                             Foreground="White"
                                                             Width="25" Height="25"/>
                                </Button>
                            </Grid>
                        </materialDesign:Card>
                    </materialDesign:Card>

                    <Button x:Name="photos_add_BTN"
                            Content="Добавить фото"
                            FontSize="22"
                            Height="40"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Click="photos_add_BTN_Click"
                            Margin="10"/>

                    <Button x:Name="iconVisible"
                            Visibility="Collapsed"
                            Content="Удалить фото"
                            FontSize="22"
                            Height="40"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Click="delit_Photo_User_BTN_Click"
                            Margin="10"/>

                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <Grid x:Name="Message"
              Visibility="Collapsed"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Background="#8C9A9A9A">

            <materialDesign:Card VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 UniformCornerRadius="10"
                                 materialDesign:ElevationAssist.Elevation="Dp5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card UniformCornerRadius="0"
                                         x:Name="BgMessage"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="20,10">
                            <materialDesign:PackIcon Kind="Warning"
                                                     x:Name="IconMSG"
                                                     Width="55" Height="55"/>
                            <Label Content="Название"
                                   x:Name="NameMSG"
                                   FontSize="36"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </materialDesign:Card>


                    <StackPanel Margin="20,5"
                                Grid.Row="1">
                        <StackPanel Margin="5">
                            <TextBlock Text="dfghnjsfgojihjksdfghngjkdfngkjnsdjfghnjkdsnfhgjknsdjfnghjsdnfjghnsdjfnghhjsdhfgjhsdjfghjdsfnghjksdhfngkjhsndkfjbhgsjkldfhnbkjlsdnfblkjsdfjklbnsdljkfnbljksdnfblkjnhsdkljfbnsdkljfnblk"
                                       MaxWidth="420"
                                       x:Name="TextMSG"
                                       FontSize="18"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5">
                            <Button x:Name="OkBT"
                                    BorderThickness="0"
                                    Content="Ок"
                                    Foreground="White"
                                    Click="OkBT_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

    </Grid>
</Window>
