<Window x:Class="Verbizky.Win.Jury"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Verbizky.Win"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Жури" Height="720" Width="1270">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Frame 168.png"
                    Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.ColumnSpan="3"
                             Grid.Row="0"
                             Background="#264c7e"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp7">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="10">
                    <Label Content="Жури"
                           x:Name="TitleName"
                           Foreground="#d6e7ff"
                           FontSize="32"
                           FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">

                    <Button x:Name="LoguotBT"
                            ToolTip="Выйти"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Height="40"
                            Click="LoguotBT_Click">
                        <materialDesign:PackIcon Kind="Logout"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>

                    <Button x:Name="ExitBT"
                            Margin="5"
                            ToolTip="Выйти"
                            Background="#C84153"
                            BorderThickness="0"
                            Padding="10"
                            Height="40"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}" Cursor="Hand" Click="ExitBT_Click">
                        <materialDesign:PackIcon Kind="ExitRun"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <TabControl Grid.Row="1"
                    VerticalContentAlignment="Center"
                    materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    Background="Transparent">
            <TabItem>
                <TabItem.Header>
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Home"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Width="45" Height="45"
                                                 Foreground="#d6e7ff"/>
                        <Label Content="Дом"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="16"
                               Padding="0"
                               Foreground="#d6e7ff"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Margin="30"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="15">
                            <Label Content="Доброе утро"
                                   x:Name="DateWelcome"
                                   FontSize="35"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Row="1"
                                         Margin="30,10,30,30"
                                         UniformCornerRadius="15"
                                         materialDesign:ElevationAssist.Elevation="Dp5">

                        <StackPanel Margin="35">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:Card Width="210"
                                     Height="210"
                                     materialDesign:ElevationAssist.Elevation="Dp8"
                                     Background="#FFC1C1C1">
                                    <materialDesign:Card Width="185" Height="185">
                                        <Grid>
                                            <Image x:Name="icon_User_IMG"
                                       Stretch="UniformToFill"/>

                                            <Button x:Name="edit_Photo_User_BTN"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Left"
                                        Background="#D35400"
                                        Visibility="Collapsed"
                                        Click="edit_Photo_User_BTN_Click"
                                        Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                        Padding="0" Margin="5"
                                        Width="45" Height="45"
                                        BorderThickness="0">
                                                <materialDesign:PackIcon Kind="ImageEdit"
                                                         Foreground="White"
                                                         Width="25" Height="25"/>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </materialDesign:Card>

                                <StackPanel Margin="10,0">
                                    <TextBox x:Name="name_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Имя"/>

                                    <TextBox x:Name="lust_Name_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Фамилия"/>

                                    <TextBox x:Name="sec_Name_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Отчество"/>

                                    <TextBox x:Name="mail_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Почта"/>

                                    <TextBox x:Name="phone_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Телефон"/>
                                </StackPanel>

                                <StackPanel Margin="10,0">
                                    <DatePicker x:Name="Dates"
                                    Width="220" FontSize="20"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                    materialDesign:HintAssist.Hint="Дата рождения"/>

                                    <PasswordBox x:Name="password_TXT"
                                     Width="220" FontSize="20"
                                     Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"
                                     Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                     materialDesign:HintAssist.Hint="Пароль"/>

                                    <PasswordBox x:Name="password_Acsess_TXT"
                                     Width="220" FontSize="20"
                                     Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"
                                     Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                     materialDesign:HintAssist.Hint="Повторение пароля"/>
                                </StackPanel>

                                <StackPanel Margin="10,0">
                                    <TextBox x:Name="Role_TXT"
                                 Width="220" FontSize="20"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                 materialDesign:HintAssist.Hint="Роль"/>

                                    <TextBox x:Name="Gender_TXT"
                                 Width="220" FontSize="20"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                 materialDesign:HintAssist.Hint="Пол"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="0,5">
                                    <Button x:Name="NOedit_User_BTN"
                                        Padding="0"
                                        Visibility="Collapsed"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}">
                                        <StackPanel Orientation="Horizontal"
                                                Margin="7,0">
                                            <materialDesign:PackIcon Kind="PencilOff"
                                                                 Width="25" Height="25"
                                                                 Foreground="White"
                                                                 VerticalAlignment="Center"/>
                                            <Label Content="Отмена"
                                               Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="edit_User_BTN"
                                        IsEnabled="True"
                                        Padding="0" Width="170"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="edit_User_BTN_Click">
                                        <StackPanel Orientation="Horizontal"
                                                Margin="7,0">
                                            <materialDesign:PackIcon Kind="Edit"
                                                                 Width="25" Height="25"
                                                                 Foreground="White"
                                                                 VerticalAlignment="Center"/>
                                            <Label Content="Редактировать"
                                               Foreground="White"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="save_User_BTN"
                                Padding="0" Margin="0,5"
                                IsEnabled="False" Width="170"
                                BorderThickness="0"
                                Background="#267e2b"
                                Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Click="save_User_BTN_Click">
                                        <StackPanel Orientation="Horizontal"
                                                Margin="7,0">
                                            <materialDesign:PackIcon Kind="ContentSave"
                                                         Width="25" Height="25"
                                                         Foreground="White"
                                                         VerticalAlignment="Center"/>
                                            <Label Content="Сохранить"
                                       Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </materialDesign:Card>


                </Grid>

            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Event"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Width="45" Height="45"
                                                 Foreground="#d6e7ff"/>
                        <Label Content="Меропреятимя"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="9"
                               Padding="0"
                               Foreground="#d6e7ff"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Margin="30"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <Grid>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        Margin="15">
                                <Label Content="Запись мероприятий"
                                       FontSize="35"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Margin="15">
                                <Button x:Name="UpdateDbUsers"
                                        Click="UpdateDbUsers_Click"
                                        Width="60" Height="60"
                                        BorderThickness="0"
                                        ToolTip="Обновить таблицу"
                                        Foreground="#d6e7ff"
                                        Padding="0">
                                    <materialDesign:PackIcon Kind="DatabaseSync"
                                                             Width="45" Height="45"/>
                                </Button>

                                <Button x:Name="scoreDbUsers"
                                        Click="scoreDbUsers_Click"
                                        Width="60" Height="60"
                                        BorderThickness="0"
                                        Margin="7,0"
                                        ToolTip="Обновить таблицу"
                                        Foreground="#d6e7ff"
                                        Padding="0">
                                    <materialDesign:PackIcon Kind="Score"
                                                             Width="45" Height="45"/>
                                </Button>

                            </StackPanel>
                        </Grid>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Row="1"
                                         Margin="30,10,30,30"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <DataGrid x:Name="UserGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ИД" Binding="{Binding Path=Id}"/>
                                <DataGridTextColumn Header="ИД Участника" Binding="{Binding Path=IdUser}"/>
                                <DataGridTextColumn Header="Фамилия Участника" Binding="{Binding Path=FIO}"/>
                                <DataGridTextColumn Header="Мероприятие" Binding="{Binding Path=EventName}"/>
                                <DataGridTextColumn Header="Оценка" Binding="{Binding Path=Score}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </materialDesign:Card>

                </Grid>

            </TabItem>

        </TabControl>


        <materialDesign:Card Grid.Row="1"
                             x:Name="score"
                             Visibility="Collapsed"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp0">
            <StackPanel Margin="15">
                <Label Content="Мастер выстовления оценок"
                       FontSize="55"
                       FontWeight="Medium"/>

                <StackPanel Margin="0,25">
                    <ComboBox x:Name="NameUser"
                              FontSize="32"
                              materialDesign:HintAssist.Hint="ФИО"
                              Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                              Margin="5"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,15">
                        <ComboBox x:Name="ScoreUser"
                                  FontSize="32"
                                  Width="135"
                                  HorizontalAlignment="Left"
                                  materialDesign:HintAssist.Hint="Оценка"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  Margin="5">
                            <ComboBoxItem Content="NULL"/>
                            <ComboBoxItem Content="2"/>
                            <ComboBoxItem Content="3"/>
                            <ComboBoxItem Content="4"/>
                            <ComboBoxItem Content="5"/>
                        </ComboBox>

                        <Button x:Name="SetScore"
                                Margin="5"
                                Content="Выстовить"
                                FontSize="26"
                                Height="55"
                                Width="195"
                                BorderThickness="0" Click="SetScore_Click"/>

                        <Button x:Name="bak"
                                Margin="5"
                                Content="Назад"
                                FontSize="26"
                                Height="55"
                                Width="195"
                                Style="{StaticResource MaterialDesignOutlinedButton}" Click="bak_Click"/>
                    </StackPanel>
                </StackPanel>
                
            </StackPanel>
        </materialDesign:Card>


        <Grid x:Name="Message"
              Visibility="Collapsed"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Background="#8C9A9A9A">

            <materialDesign:Card VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 UniformCornerRadius="10"
                                 materialDesign:ElevationAssist.Elevation="Dp5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card UniformCornerRadius="0"
                                         x:Name="BgMessage"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="20,10">
                            <materialDesign:PackIcon Kind="Warning"
                                                     x:Name="IconMSG"
                                                     Width="55" Height="55"/>
                            <Label Content="Название"
                                   x:Name="NameMSG"
                                   FontSize="36"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </materialDesign:Card>


                    <StackPanel Margin="20,5"
                                Grid.Row="1">
                        <StackPanel Margin="5">
                            <TextBlock Text="dfghnjsfgojihjksdfghngjkdfngkjnsdjfghnjkdsnfhgjknsdjfnghjsdnfjghnsdjfnghhjsdhfgjhsdjfghjdsfnghjksdhfngkjhsndkfjbhgsjkldfhnbkjlsdnfblkjsdfjklbnsdljkfnbljksdnfblkjnhsdkljfbnsdkljfnblk"
                                       MaxWidth="420"
                                       x:Name="TextMSG"
                                       FontSize="18"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5">
                            <Button x:Name="OkBT"
                                    BorderThickness="0"
                                    Content="Ок"
                                    Foreground="White"
                                    Click="OkBT_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

    </Grid>
</Window>
