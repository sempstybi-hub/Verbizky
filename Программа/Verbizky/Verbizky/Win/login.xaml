<Window x:Class="Verbizky.Win.login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Verbizky.Win"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Вход" Height="720" Width="1270">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Frame 168.png"
                    Stretch="UniformToFill"/>
    </Window.Background>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <materialDesign:Card
                             Grid.Row="0"
                             Background="#264c7e"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp7">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="10">
                    <Label Content="Вход"
                           Foreground="#d6e7ff"
                           FontSize="32"
                           FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">

                    <Button x:Name="HomeBT"
                            ToolTip="На главную"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Height="40" Click="HomeBT_Click">
                        <materialDesign:PackIcon Kind="Home"
                                                 Width="22"
                                                 Height="22"
                                                 VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ExitBT"
                            Margin="5"
                            ToolTip="Выйти"
                            Background="#C84153"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="White"
                            Height="40"
                            Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}" Click="ExitBT_Click">
                        <materialDesign:PackIcon Kind="ExitRun"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="1"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             Background="#DDDDDD"
                             materialDesign:ElevationAssist.Elevation="Dp5"
                             UniformCornerRadius="10"
                             Width="600" Height="220">
            <StackPanel Margin="20">
                <TextBox x:Name="LoginTXT"
                         Margin="7"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         materialDesign:HintAssist.Hint="Почта"
                         FontSize="22"/>
                <PasswordBox x:Name="PasswrdTXT"
                             Margin="7"
                             Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"
                             materialDesign:HintAssist.Hint="Пароль"
                             FontSize="22"/>
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="LogInBT"
                            Content="Войти"
                            Foreground="White"
                            FontSize="22"
                            Width="120"
                            Height="42"
                            Margin="5" Click="LogInBT_Click"/>
                    <Button x:Name="RegBT"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Content="Зарегистроваться"
                            FontSize="22"
                            Width="240"
                            Height="42"
                            Margin="5"
                            Click="NoAccBT_Click"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <Grid Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Visibility="Collapsed"
              x:Name="Captcha"
              Background="#8C9A9A9A">
            <materialDesign:Card materialDesign:ElevationAssist.Elevation="Dp7"
                                 UniformCornerRadius="10"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center">
                <StackPanel Margin="30">
                    <Label Content="КАПЧА"
                           FontWeight="Black"
                           FontSize="50"
                           HorizontalAlignment="Center"/>

                    <Label x:Name="CaptchaCode"
                           FontSize="38"
                           Content="3454 - 3421"
                           HorizontalAlignment="Center"/>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center">
                        <TextBox x:Name="Code1" Width="100" MaxLength="4"
                                 HorizontalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="Код 1"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="22"/>

                        <Label Margin="5,0"
                               Content="-"
                               Padding="0"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="30"/>

                        <TextBox x:Name="Code2" Width="100" MaxLength="4"
                                 HorizontalContentAlignment="Center"
                                 materialDesign:HintAssist.Hint="Код 2"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="22"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,20,0,5">
                        <Button x:Name="CheckCaptcha"
                                Click="CheckCaptcha_Click"
                                FontSize="18"
                                Margin="0,0,5,0"
                                Content="Проверить"/>

                        <Button x:Name="CloseCaptcha"
                                Click="CloseCaptcha_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                FontSize="18"
                                Margin="0,0,5,0"
                                Content="Отмена"/>
                    </StackPanel>
                    
                </StackPanel>
            </materialDesign:Card>
        </Grid>

        <Grid x:Name="Message"
              Visibility="Collapsed"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Background="#8C9A9A9A">

            <materialDesign:Card VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 UniformCornerRadius="10"
                                 materialDesign:ElevationAssist.Elevation="Dp5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card UniformCornerRadius="0"
                                         x:Name="BgMessage"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="20,10">
                            <materialDesign:PackIcon Kind="Warning"
                                                     x:Name="IconMSG"
                                                     Width="55" Height="55"/>
                            <Label Content="Название"
                                   x:Name="NameMSG"
                                   FontSize="36"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </materialDesign:Card>


                    <StackPanel Margin="20,5"
                                Grid.Row="1">
                        <StackPanel Margin="5">
                            <TextBlock Text="dfghnjsfgojihjksdfghngjkdfngkjnsdjfghnjkdsnfhgjknsdjfnghjsdnfjghnsdjfnghhjsdhfgjhsdjfghjdsfnghjksdhfngkjhsndkfjbhgsjkldfhnbkjlsdnfblkjsdfjklbnsdljkfnbljksdnfblkjnhsdkljfbnsdkljfnblk"
                                       MaxWidth="420"
                                       x:Name="TextMSG"
                                       FontSize="18"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5">
                            <Button x:Name="OkBT"
                                    BorderThickness="0"
                                    Content="Ок"
                                    Click="OkBT_Click"
                                    Foreground="White"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>
        
        
    </Grid>
</Window>
