<Window x:Class="Verbizky.Win.MainUser"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Verbizky.Win"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="MainUser" Height="720" Width="1270">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Frame 168.png"
                    Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="270"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.ColumnSpan="3"
                             Grid.Row="0"
                             Background="#264c7e"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp7">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="10">
                    <Label Content="Главная - гость"
                           x:Name="TitleName"
                           Foreground="#d6e7ff"
                           FontSize="32"
                           FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">

                    <Button x:Name="UpdCardBT"
                            ToolTip="Обновить карточки"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Height="40"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Click="UpdCardBT_Click">
                        <materialDesign:PackIcon Kind="DatabaseSync"
                                                 Width="22"
                                                 Height="22"
                                                 VerticalAlignment="Center"/>
                    </Button>

                    <Button x:Name="AccBT"
                            Visibility="Collapsed"
                            ToolTip="Аккаунт"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Height="40"
                            Click="AccBT_Click">
                        <materialDesign:PackIcon Kind="Account"
                                                 Width="22"
                                                 Height="22"
                                                 VerticalAlignment="Center"/>
                    </Button>

                    <Button x:Name="LogInBT"
                            ToolTip="Войти"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Height="40"
                            Click="LogInBT_Click">
                        <materialDesign:PackIcon Kind="Login"
                                                 Width="22"
                                                 Height="22"
                                                 VerticalAlignment="Center"/>
                    </Button>
                    <Button x:Name="ExitBT"
                            Margin="5"
                            ToolTip="Выйти"
                            Background="#C84153"
                            BorderThickness="0"
                            Padding="10"
                            Height="40"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}" Cursor="Hand" Click="ExitBT_Click">
                        <materialDesign:PackIcon Kind="ExitRun"
                                                 Width="22"
                                                 Height="22"
                                                 VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="1">
            <materialDesign:Card Padding="4" Width="65" Height="65"
                                 x:Name="Load"
                                 Background="#264c7e"
                                 materialDesign:ElevationAssist.Elevation="Dp3"
                                 UniformCornerRadius="50">
                <Grid>
                    <ProgressBar IsIndeterminate="True"
                                 Foreground="#d6e7ff"
                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Width="55" Height="55"/>
                </Grid>
            </materialDesign:Card>
            <ListView Margin="0"
                      x:Name="Lists"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      materialDesign:ListBoxItemAssist.ShowSelection="False"
                      ScrollViewer.CanContentScroll="False"
                      VirtualizingPanel.ScrollUnit="Pixel">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="5"
                                             x:Name="Crd"
                                             HorizontalAlignment="Stretch"
                                             HorizontalContentAlignment="Stretch"
                                             UniformCornerRadius="15"
                                             materialDesign:ElevationAssist.Elevation="Dp5">
                            <Grid Background="#DDDDDD"
                                  HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <materialDesign:Card Margin="15"
                                                     Width="250" Height="250"
                                                     UniformCornerRadius="15"
                                                     materialDesign:ElevationAssist.Elevation="Dp2">

                                    <Grid>
                                        <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                                     IsIndeterminate="True"
                                                     Width="55" Height="55"/>
                                        <Image Width="250" Height="250"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Stretch="UniformToFill"
                                               Source="{Binding ImageSource}"/>
                                    </Grid>
                                    
                                </materialDesign:Card>

                                <StackPanel Grid.Column="1"
                                            Margin="5"
                                            HorizontalAlignment="Stretch"
                                            >
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="55"
                                               FontWeight="Bold"
                                               Margin="5"
                                               Foreground="#264c7e"/>
                                    <TextBlock Text="{Binding Event}"
                                               TextWrapping="Wrap"
                                               FontSize="22"
                                               Margin="5"/>

                                    <StackPanel>
                                        <TextBlock Margin="5,2"
                                                   Padding="0"
                                                   FontSize="16">
                                                <Run Text="Дата проведения: "/>
                                                <Run Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}"/>
                                        </TextBlock>

                                        <TextBlock Margin="5,2"
                                                   Padding="0"
                                                   FontSize="16">
                                                <Run Text="Длительность: "/>
                                                <Run Text="{Binding Days}"/>
                                                <Run Text=" Дней"/>
                                        </TextBlock>

                                        <TextBlock Margin="5,2"
                                                   Padding="0"
                                                   FontSize="16">
                                                <Run Text="Город: "/>
                                                <Run Text="{Binding City.Name}"/>
                                        </TextBlock>

                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="SubscribeBTNS"
                                                materialDesign:ButtonProgressAssist.IsIndeterminate="False"
                                                materialDesign:ButtonProgressAssist.IsIndicatorVisible="True"
                                                materialDesign:ButtonProgressAssist.Value="-1"
                                                Padding="0"
                                                Width="150"
                                                Tag="{Binding Id}"
                                                Click="SubscribeBTNS_Click"
                                                BorderThickness="0"
                                                HorizontalAlignment="Left"
                                                Margin="10">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Plus"
                                                                         Width="20" Height="20"
                                                                         Foreground="White"
                                                                         VerticalAlignment="Center"/>
                                                <Label Content="Учавствовать"
                                                       VerticalAlignment="Center"
                                                       Foreground="White"/>
                                            </StackPanel>
                                        </Button>


                                        <StackPanel Orientation="Horizontal"
                                                    x:Name="DoneCardUser">
                                            <materialDesign:PackIcon Kind="Check"
                                                                     Width="26" Height="26"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="#267e2b"/>
                                            <Label Content="Участвуите"
                                                   FontSize="26"
                                                   Foreground="#267e2b"/>

                                            <Button x:Name="DoneBTNS"
                                                    Visibility="Visible"
                                                    Padding="0"
                                                    Background="#7D2B25"
                                                    BorderThickness="0"
                                                    Width="210"
                                                    Tag="{Binding Id}"
                                                    Click="DoneBTNS_Click"
                                                    HorizontalAlignment="Left"
                                                    Margin="10">
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Minus"
                                                                             Width="20" Height="20"
                                                                             Foreground="White"
                                                                             VerticalAlignment="Center"/>
                                                    <Label Content="Прекратить участие"
                                                           VerticalAlignment="Center"
                                                           Foreground="White"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>

                                    </StackPanel>

                                </StackPanel>

                            </Grid>
                        </materialDesign:Card>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <materialDesign:Card Grid.Row="1" Grid.Column="1"
                             Background="#DDDDDD"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp7">
            <StackPanel Margin="7">
                <ComboBox x:Name="NameFilCB"
                          materialDesign:HintAssist.Hint="Фильтр по именам"
                          Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                          FontSize="22" />
                <Button x:Name="SetNameFilCbBT"
                        Content="Применить"
                        Margin="5,5,5,15"
                        Click="SetNameFilCbBT_Click"/>

                <DatePicker x:Name="DateFiltDP"
                            materialDesign:HintAssist.Hint="Дата"
                            FontSize="22"
                            Style="{StaticResource MaterialDesignFloatingHintDatePicker}"/>
                <Button x:Name="DateSetFilDpBT"
                        Content="Применить"
                        Margin="5,5,5,15"
                        Click="DateSetFilDpBT_Click"/>

                <Separator Style="{StaticResource MaterialDesignDarkSeparator}"/>

                <Button x:Name="DefoltFilBT"
                        Content="Сбросить фильтры"
                        Background="#787e26"
                        BorderThickness="0"
                        Margin="5"
                        Click="DefoltFilBT_Click"/>
                

            </StackPanel>
        </materialDesign:Card>

        <Grid x:Name="Message"
              Visibility="Collapsed"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Background="#8C9A9A9A">

            <materialDesign:Card VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 UniformCornerRadius="10"
                                 materialDesign:ElevationAssist.Elevation="Dp5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card UniformCornerRadius="0"
                                         x:Name="BgMessage"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="20,10">
                            <materialDesign:PackIcon Kind="Warning"
                                                     x:Name="IconMSG"
                                                     Width="55" Height="55"/>
                            <Label Content="Название"
                                   x:Name="NameMSG"
                                   FontSize="36"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </materialDesign:Card>


                    <StackPanel Margin="20,5"
                                Grid.Row="1">
                        <StackPanel Margin="5">
                            <TextBlock Text="dfghnjsfgojihjksdfghngjkdfngkjnsdjfghnjkdsnfhgjknsdjfnghjsdnfjghnsdjfnghhjsdhfgjhsdjfghjdsfnghjksdhfngkjhsndkfjbhgsjkldfhnbkjlsdnfblkjsdfjklbnsdljkfnbljksdnfblkjnhsdkljfbnsdkljfnblk"
                                       MaxWidth="420"
                                       x:Name="TextMSG"
                                       FontSize="18"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5">
                            <Button x:Name="OkBT"
                                    BorderThickness="0"
                                    Content="Ок"
                                    Foreground="White"
                                    Click="OkBT_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Window>
