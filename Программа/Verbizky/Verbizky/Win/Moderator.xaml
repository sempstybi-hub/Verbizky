<Window x:Class="Verbizky.Win.Moderator"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:Verbizky.Win"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="Модератор" Height="720" Width="1270">

    <Window.Background>
        <ImageBrush ImageSource="/Resources/Frame 168.png"
                    Stretch="UniformToFill"/>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <materialDesign:Card Grid.ColumnSpan="3"
                             Grid.Row="0"
                             Background="#264c7e"
                             UniformCornerRadius="0"
                             materialDesign:ElevationAssist.Elevation="Dp7">
            <Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            Margin="10">
                    <Label Content="Модератор"
                           x:Name="TitleName"
                           Foreground="#d6e7ff"
                           FontSize="32"
                           FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="10">

                    <Button x:Name="LoguotBT"
                            ToolTip="Выйти"
                            Margin="5"
                            BorderThickness="0"
                            Padding="10"
                            Foreground="#264c7e"
                            Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                            Height="40"
                            Click="LoguotBT_Click">
                        <materialDesign:PackIcon Kind="Logout"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>

                    <Button x:Name="ExitBT"
                            Margin="5"
                            ToolTip="Выйти"
                            Background="#C84153"
                            BorderThickness="0"
                            Padding="10"
                            Height="40"
                            Foreground="White"
                            Style="{StaticResource MaterialDesignRaisedSecondaryDarkButton}" Cursor="Hand" Click="ExitBT_Click">
                        <materialDesign:PackIcon Kind="ExitRun"
                                         Width="22"
                                         Height="22"
                                         VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <TabControl Grid.Row="1"
                    VerticalContentAlignment="Center"
                    materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                    Style="{StaticResource MaterialDesignNavigationRailTabControl}"
                    Background="Transparent">
            <TabItem>
                <TabItem.Header>
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Home"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Width="45" Height="45"
                                                 Foreground="#d6e7ff"/>
                        <Label Content="Дом"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="16"
                               Padding="0"
                               Foreground="#d6e7ff"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card Margin="30"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="15">
                            <Label Content="Доброе утро"
                                   x:Name="DateWelcome"
                                   FontSize="35"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Row="1"
                                         Margin="30,10,30,30"
                                         UniformCornerRadius="15"
                                         materialDesign:ElevationAssist.Elevation="Dp5">

                        <StackPanel Margin="35">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:Card Width="210"
                                     Height="210"
                                     materialDesign:ElevationAssist.Elevation="Dp8"
                                     Background="#FFC1C1C1">
                                    <materialDesign:Card Width="185" Height="185">
                                        <Grid>
                                            <Image x:Name="icon_User_IMG"
                                       Stretch="UniformToFill"/>

                                            <Button x:Name="edit_Photo_User_BTN"
                                        VerticalAlignment="Bottom"
                                        HorizontalAlignment="Left"
                                        Background="#D35400"
                                        Visibility="Collapsed"
                                        Click="edit_Photo_User_BTN_Click"
                                        Style="{StaticResource MaterialDesignRaisedSecondaryButton}"
                                        Padding="0" Margin="5"
                                        Width="45" Height="45"
                                        BorderThickness="0">
                                                <materialDesign:PackIcon Kind="ImageEdit"
                                                         Foreground="White"
                                                         Width="25" Height="25"/>
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </materialDesign:Card>

                                <StackPanel Margin="10,0">
                                    <TextBox x:Name="name_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Имя"/>

                                    <TextBox x:Name="lust_Name_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Фамилия"/>

                                    <TextBox x:Name="sec_Name_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Отчество"/>

                                    <TextBox x:Name="mail_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Почта"/>

                                    <TextBox x:Name="phone_TXT"
                             Width="220" FontSize="20"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             Padding="0" Margin="0,20,0,0" IsEnabled="False"
                             materialDesign:HintAssist.Hint="Телефон"/>
                                </StackPanel>

                                <StackPanel Margin="10,0">
                                    <DatePicker x:Name="Dates"
                                    Width="220" FontSize="20"
                                    Style="{StaticResource MaterialDesignFloatingHintDatePicker}"
                                    Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                    materialDesign:HintAssist.Hint="Дата рождения"/>

                                    <PasswordBox x:Name="password_TXT"
                                     Width="220" FontSize="20"
                                     Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"
                                     Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                     materialDesign:HintAssist.Hint="Пароль"/>

                                    <PasswordBox x:Name="password_Acsess_TXT"
                                     Width="220" FontSize="20"
                                     Style="{StaticResource MaterialDesignFloatingHintRevealPasswordBox}"
                                     Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                     materialDesign:HintAssist.Hint="Повторение пароля"/>
                                </StackPanel>

                                <StackPanel Margin="10,0">
                                    <TextBox x:Name="Role_TXT"
                                 Width="220" FontSize="20"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                 materialDesign:HintAssist.Hint="Роль"/>

                                    <TextBox x:Name="Gender_TXT"
                                 Width="220" FontSize="20"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 Padding="0" Margin="0,20,0,0" IsEnabled="False"
                                 materialDesign:HintAssist.Hint="Пол"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <StackPanel Margin="0,5">
                                    <Button x:Name="NOedit_User_BTN"
                                        Padding="0"
                                        Visibility="Collapsed"
                                        Style="{StaticResource MaterialDesignRaisedDarkButton}">
                                        <StackPanel Orientation="Horizontal"
                                                Margin="7,0">
                                            <materialDesign:PackIcon Kind="PencilOff"
                                                                 Width="25" Height="25"
                                                                 Foreground="White"
                                                                 VerticalAlignment="Center"/>
                                            <Label Content="Отмена"
                                               Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="edit_User_BTN"
                                        IsEnabled="True"
                                        Padding="0" Width="170"
                                        Style="{StaticResource MaterialDesignRaisedButton}"
                                Click="edit_User_BTN_Click">
                                        <StackPanel Orientation="Horizontal"
                                                Margin="7,0">
                                            <materialDesign:PackIcon Kind="Edit"
                                                                 Width="25" Height="25"
                                                                 Foreground="White"
                                                                 VerticalAlignment="Center"/>
                                            <Label Content="Редактировать"
                                               Foreground="White"/>
                                        </StackPanel>
                                    </Button>

                                    <Button x:Name="save_User_BTN"
                                Padding="0" Margin="0,5"
                                IsEnabled="False" Width="170"
                                BorderThickness="0"
                                Background="#267e2b"
                                Style="{StaticResource MaterialDesignRaisedSecondaryButton}" Click="save_User_BTN_Click">
                                        <StackPanel Orientation="Horizontal"
                                                Margin="7,0">
                                            <materialDesign:PackIcon Kind="ContentSave"
                                                         Width="25" Height="25"
                                                         Foreground="White"
                                                         VerticalAlignment="Center"/>
                                            <Label Content="Сохранить"
                                       Foreground="White"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>

                    </materialDesign:Card>


                </Grid>

            </TabItem>

            <TabItem>
                <TabItem.Header>
                    <StackPanel>
                        <materialDesign:PackIcon Kind="Events"
                                                 VerticalAlignment="Center"
                                                 HorizontalAlignment="Center"
                                                 Width="45" Height="45"
                                                 Foreground="#d6e7ff"/>
                        <Label Content="Мероприятния"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="9"
                               Padding="0"
                               Foreground="#d6e7ff"/>
                    </StackPanel>
                </TabItem.Header>

                <Grid Grid.Row="1">
                    <ListView Margin="0"
              x:Name="Lists"
              HorizontalContentAlignment="Stretch"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              materialDesign:ListBoxItemAssist.ShowSelection="False"
              ScrollViewer.CanContentScroll="False"
              VirtualizingPanel.ScrollUnit="Pixel">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <materialDesign:Card Margin="5"
                                     x:Name="Crd"
                                     HorizontalAlignment="Stretch"
                                     HorizontalContentAlignment="Stretch"
                                     UniformCornerRadius="15"
                                     materialDesign:ElevationAssist.Elevation="Dp5">
                                    <Grid Background="#DDDDDD"
                          HorizontalAlignment="Stretch">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="auto"/>
                                            <ColumnDefinition />
                                        </Grid.ColumnDefinitions>
                                        <materialDesign:Card Margin="15"
                                             Width="250" Height="250"
                                             UniformCornerRadius="15"
                                             materialDesign:ElevationAssist.Elevation="Dp2">

                                            <Grid>
                                                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                             IsIndeterminate="True"
                                             Width="55" Height="55"/>
                                                <Image Width="250" Height="250"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Stretch="UniformToFill"
                                       Source="{Binding ImageSource}"/>
                                            </Grid>

                                        </materialDesign:Card>

                                        <StackPanel Grid.Column="1"
                                    Margin="5"
                                    HorizontalAlignment="Stretch"
                                    >
                                            <TextBlock Text="{Binding Name}"
                                       FontSize="55"
                                       FontWeight="Bold"
                                       Margin="5"
                                       Foreground="#264c7e"/>
                                            <TextBlock Text="{Binding Event}"
                                       TextWrapping="Wrap"
                                       FontSize="22"
                                       Margin="5"/>

                                            <StackPanel>
                                                <TextBlock Margin="5,2"
                                           Padding="0"
                                           FontSize="16">
                                        <Run Text="Дата проведения: "/>
                                        <Run Text="{Binding Date, StringFormat='{}{0:dd.MM.yyyy}'}"/>
                                                </TextBlock>

                                                <TextBlock Margin="5,2"
                                           Padding="0"
                                           FontSize="16">
                                        <Run Text="Длительность: "/>
                                        <Run Text="{Binding Days}"/>
                                        <Run Text=" Дней"/>
                                                </TextBlock>

                                                <TextBlock Margin="5,2"
                                           Padding="0"
                                           FontSize="16">
                                        <Run Text="Город: "/>
                                        <Run Text="{Binding City.Name}"/>
                                                </TextBlock>

                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <Button x:Name="SubscribeBTNS"
                                        materialDesign:ButtonProgressAssist.IsIndeterminate="False"
                                        materialDesign:ButtonProgressAssist.IsIndicatorVisible="True"
                                        materialDesign:ButtonProgressAssist.Value="-1"
                                        Padding="0"
                                        Width="150"
                                        Tag="{Binding Id}"
                                        Click="SubscribeBTNS_Click"
                                        BorderThickness="0"
                                        HorizontalAlignment="Left"
                                        Margin="10">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Plus"
                                                                 Width="20" Height="20"
                                                                 Foreground="White"
                                                                 VerticalAlignment="Center"/>
                                                        <Label Content="Учавствовать"
                                               VerticalAlignment="Center"
                                               Foreground="White"/>
                                                    </StackPanel>
                                                </Button>


                                                <StackPanel Orientation="Horizontal"
                                            x:Name="DoneCardUser">
                                                    <materialDesign:PackIcon Kind="Check"
                                                             Width="26" Height="26"
                                                             VerticalAlignment="Center"
                                                             Foreground="#267e2b"/>
                                                    <Label Content="Участвуите"
                                           FontSize="26"
                                           Foreground="#267e2b"/>

                                                    <Button x:Name="DoneBTNS"
                                            Visibility="Visible"
                                            Padding="0"
                                            Background="#7D2B25"
                                            BorderThickness="0"
                                            Width="210"
                                            Tag="{Binding Id}"
                                            Click="DoneBTNS_Click"
                                            HorizontalAlignment="Left"
                                            Margin="10">
                                                        <StackPanel Orientation="Horizontal">
                                                            <materialDesign:PackIcon Kind="Minus"
                                                                     Width="20" Height="20"
                                                                     Foreground="White"
                                                                     VerticalAlignment="Center"/>
                                                            <Label Content="Прекратить участие"
                                                   VerticalAlignment="Center"
                                                   Foreground="White"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>

                                            </StackPanel>

                                        </StackPanel>

                                    </Grid>
                                </materialDesign:Card>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>

            </TabItem>

        </TabControl>

        <Grid x:Name="Message"
              Visibility="Collapsed"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Background="#8C9A9A9A">

            <materialDesign:Card VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 UniformCornerRadius="10"
                                 materialDesign:ElevationAssist.Elevation="Dp5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <materialDesign:Card UniformCornerRadius="0"
                                         x:Name="BgMessage"
                                         materialDesign:ElevationAssist.Elevation="Dp5">
                        <StackPanel Orientation="Horizontal"
                                    Margin="20,10">
                            <materialDesign:PackIcon Kind="Warning"
                                                     x:Name="IconMSG"
                                                     Width="55" Height="55"/>
                            <Label Content="Название"
                                   x:Name="NameMSG"
                                   FontSize="36"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"/>
                        </StackPanel>
                    </materialDesign:Card>


                    <StackPanel Margin="20,5"
                                Grid.Row="1">
                        <StackPanel Margin="5">
                            <TextBlock Text="dfghnjsfgojihjksdfghngjkdfngkjnsdjfghnjkdsnfhgjknsdjfnghjsdnfjghnsdjfnghhjsdhfgjhsdjfghjdsfnghjksdhfngkjhsndkfjbhgsjkldfhnbkjlsdnfblkjsdfjklbnsdljkfnbljksdnfblkjnhsdkljfbnsdkljfnblk"
                                       MaxWidth="420"
                                       x:Name="TextMSG"
                                       FontSize="18"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,5">
                            <Button x:Name="OkBT"
                                    BorderThickness="0"
                                    Content="Ок"
                                    Foreground="White"
                                    Click="OkBT_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>

    </Grid>
</Window>
